APP_NAME=Revoco
APP_ENV=local
# APP_KEY is REQUIRED in production. Generate once before first boot:
#   docker run --rm <image> php artisan key:generate --show
# Copy the output (base64:...) here. The container exits non-zero if APP_KEY
# is missing in production — it never auto-generates one.
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8580

APP_LOCALE=de
APP_FALLBACK_LOCALE=de
APP_FAKER_LOCALE=de_DE

# The languages the consumer form offers (and its default) are managed by the
# operator in the Filament panel under Settings → Localization, not via .env.
# On first migrate they are seeded from APP_LOCALE (shipped consumer translations:
# de, en).

# Consumer-local time for stored/displayed withdrawal timestamps (§ 356a Abs. 4).
APP_TIMEZONE=Europe/Berlin

# Active visual theme — switches the --wf-* token set via data-theme.
# Neutral ships here; brand overlays live in the private infra repo.
APP_THEME=neutral

# Branding — neutral placeholders; override per deployment. No real brand
# assets in this public repo. Empty logo = reserved empty slot.
REVOCO_BRAND_NAME=
REVOCO_LOGO_URL=
REVOCO_IMPRINT_URL=
REVOCO_PRIVACY_URL=

# AGPL-3.0 §13 source-code link shown in the form footer. Left unset it defaults to
# the upstream repository (correct for an UNMODIFIED deployment). If you MODIFY the
# code, uncomment and point this at your own corresponding source (your fork).
# REVOCO_SOURCE_URL=

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# In production (Docker), the SQLite file lives on the app_storage named volume.
# Default path inside the container:
# DB_DATABASE=/var/www/html/storage/database/database.sqlite
# Leave blank to use Laravel's default (database/database.sqlite relative to project root).
# DB_DATABASE=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# QUEUE_CONNECTION: use "database" with SQLite. The queue worker (docker compose
# `queue` service) processes jobs; the scheduler (`scheduler` service) dispatches them.
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail — in dev, "log" mailer writes to storage/logs (safe; no real mail sent).
# In production, set MAIL_MAILER=smtp and configure the fields below.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Operator panel — credentials for the single admin account.
#
# Two provisioning paths:
#
#   (A) Automated / deploy:  set OPERATOR_EMAIL + OPERATOR_PASSWORD here, then
#       run `task operator`.  The task reads these values and passes them as
#       --email / --password to `php artisan app:operator`.  The password can
#       be removed from .env after the first successful run.
#
#   (B) Interactive:  leave these blank and run `php artisan app:operator`
#       directly — the command will prompt for the e-mail and password.
#
OPERATOR_EMAIL=
OPERATOR_PASSWORD=

# Operator panel UI language — independent of APP_LOCALE (consumer form).
# Supported: en (default), de. Falls back to en for any unsupported value.
BACKEND_LOCALE=en

# Delivery — merchant notification + optional ntfy push (async via queue worker).
# Operator notification address (full case data + spam status). Empty = no merchant mail.
MERCHANT_NOTIFICATION_EMAIL=
# ntfy push: opt-in, data-minimal (no PII). Server/topic + optional access token.
# To run a bundled ntfy instance: docker compose ... --profile ntfy up
# Set NTFY_ENABLED=true and configure NTFY_SERVER + NTFY_TOPIC.
NTFY_ENABLED=false
NTFY_SERVER=https://ntfy.sh
NTFY_TOPIC=
NTFY_TOKEN=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
